name: vulnerable-demo-deploy

environment: production
debug: true

server:
  host: 0.0.0.0
  port: 8081
  force_https: false

cors:
  enabled: true
  allowed_origins:
    - "*"

database:
  type: postgres
  host: db.internal.local
  port: 5432
  name: app_prod
  username: admin
  password: admin123

auth:
  jwt_secret: "supersecret123"
  mfa_required: false
  session_timeout_minutes: 10080

logging:
  level: debug
  log_sensitive_data: true

security:
  rate_limit_enabled: false
  input_validation_enabled: false
  dependency_scan_enabled: false
  secret_scan_enabled: false

deploy:
  run_as_root: true
  auto_approve: true
  rollback_enabled: false
